name: Custom React Deploy

on:
  push:
    branches: [main] # Runs every time you push to main

permissions:
  contents: read
  pages: write
  id-token: write

jobs:
  build_and_deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: 'npm'

      - name: Install Dependencies
        # CI=true prevents the "Do you want to install X?" questions
        run: npm ci 

      - name: Build Project
        run: npm run build

      - name: Upload to GH Pages
        uses: actions/upload-pages-artifact@v3
        with:
          path: './dist' # Vite always outputs to dist

      - name: Deploy
        uses: actions/deploy-pages@v4
